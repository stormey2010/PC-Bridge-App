<Application x:Class="PcBridge.Agent.App.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#6D5DFB"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#15151D"/>
    <SolidColorBrush x:Key="CardBrush" Color="#1D1D27"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#2C2C3A"/>
    <SolidColorBrush x:Key="TextBrush" Color="#F5F4FA"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#A5A3B5"/>
    <Style TargetType="Window"><Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/><Setter Property="Background" Value="#101017"/><Setter Property="Foreground" Value="{StaticResource TextBrush}"/></Style>
    <Style x:Key="NavButton" TargetType="Button"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource MutedBrush}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Padding" Value="14,10"/><Setter Property="Margin" Value="8,2"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontSize" Value="14"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" CornerRadius="9" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#252533"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="Tag" Value="selected"><Setter TargetName="Root" Property="Background" Value="#2B2852"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="PrimaryButton" TargetType="Button"><Setter Property="Background" Value="{StaticResource AccentBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="18,10"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Opacity" Value=".86"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Opacity" Value=".7"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}"><Setter Property="Background" Value="#292936"/><Setter Property="Foreground" Value="{StaticResource TextBrush}"/></Style>
    <Style x:Key="Card" TargetType="Border"><Setter Property="Background" Value="{StaticResource CardBrush}"/><Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="14"/><Setter Property="Padding" Value="18"/><Setter Property="Margin" Value="0,0,14,14"/></Style>
    <Style TargetType="TextBox"><Setter Property="Background" Value="#20202A"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#363646"/><Setter Property="Padding" Value="12,9"/><Setter Property="CaretBrush" Value="White"/><Setter Property="FontSize" Value="14"/></Style>
    <Style TargetType="PasswordBox"><Setter Property="Background" Value="#20202A"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#363646"/><Setter Property="Padding" Value="12,9"/></Style>
  </Application.Resources>
</Application>
