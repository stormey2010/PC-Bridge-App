<Window x:Class="PcBridge.Agent.App.SetupWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Set up PC Bridge Agent" Width="720" Height="660" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#101017" Foreground="#F5F4FA" FontFamily="Segoe UI Variable Text, Segoe UI">
  <Grid Margin="48,36"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel><Border Width="48" Height="48" CornerRadius="14" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left"><TextBlock Text="⌁" FontSize="31" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="Connect this PC" FontSize="30" FontWeight="SemiBold" Margin="0,20,0,6"/><TextBlock Text="PC Bridge makes an encrypted outbound connection to Home Assistant. No inbound firewall rule is needed." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="14"/></StackPanel>
    <StackPanel Grid.Row="1" Margin="0,28,0,0"><TextBlock Text="HOME ASSISTANT URL" FontSize="11" Foreground="{StaticResource MutedBrush}"/><TextBox x:Name="UrlBox" Margin="0,7,0,17" ToolTip="For example, https://home.example.com"/><TextBlock Text="LONG-LIVED ACCESS TOKEN" FontSize="11" Foreground="{StaticResource MutedBrush}"/><PasswordBox x:Name="TokenBox" Margin="0,7,0,6"/><TextBlock Text="Leave blank to keep and test the existing saved credential. New tokens are protected with Windows DPAPI." FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/><TextBlock Text="DEVICE NAME" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,17,0,0"/><TextBox x:Name="DeviceBox" Margin="0,7,0,17"/><CheckBox x:Name="PrivacyBox" Content="Enable privacy-sensitive activity sensors" Foreground="{StaticResource TextBrush}"/><TextBlock x:Name="StatusText" Foreground="#FF8A8A" Margin="0,18,0,0" TextWrapping="Wrap"/></StackPanel>
    <Grid Grid.Row="2"><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Test connection" Style="{StaticResource SecondaryButton}" Margin="0,0,9,0" Click="Test_Click"/><Button x:Name="SaveButton" Content="Connect &amp; finish" Style="{StaticResource PrimaryButton}" IsEnabled="False" Click="Save_Click"/></StackPanel></Grid>
  </Grid>
</Window>
